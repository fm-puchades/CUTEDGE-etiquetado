+    @staticmethod
+    def _draw_reference_scale(image: Image.Image) -> Image.Image:
+        """Draw a non-calibrated visual reference scale on the preview only."""
+        preview = image.copy()
+        draw = ImageDraw.Draw(preview)
+        width, height = preview.size
+        if width < 120 or height < 120:
+            return preview
+
+        x = 22
+        y0 = 28
+        y1 = height - 28
+        white = (245, 245, 245)
+        black = (0, 0, 0)
+
+        # Shadow for readability over bright or dark images.
+        draw.line((x + 1, y0 + 1, x + 1, y1 + 1), fill=black, width=3)
+        draw.line((x, y0, x, y1), fill=white, width=2)
+
+        for i in range(11):
+            y = int(y0 + (y1 - y0) * i / 10)
+            if i in {0, 5, 10}:
+                tick_len = 22
+            elif i % 2 == 0:
+                tick_len = 16
+            else:
+                tick_len = 10
+
+            draw.line((x, y, x + tick_len, y), fill=black, width=4)
+            draw.line((x, y, x + tick_len, y), fill=white, width=2)
+
+            if i in {0, 5, 10}:
+                label = str(i * 10)
+                tx = x + tick_len + 5
+                ty = max(0, min(height - 12, y - 6))
+                draw.text((tx + 1, ty + 1), label, fill=black)
+                draw.text((tx, ty), label, fill=white)
+
+        draw.text((x - 4, max(4, y0 - 20)), "ref", fill=black)
+        draw.text((x - 5, max(3, y0 - 21)), "ref", fill=white)
